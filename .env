# LLM_MODEL=mistral

EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
LLM_PROVIDER=ollama
LLM_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# LLM Configuration
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1500
 
# Retrieval Configuration (Optimized for speed)
RETRIEVAL_TOP_K=6
CHUNK_SIZE=500
CHUNK_OVERLAP=150

# Knowledge Graph Configuration (Optimized)
USE_NETWORKX_KG=true
KG_MAX_HOPS=1
KG_TOP_ENTITIES=3

# Hybrid Retrieval (Favor vector DB for better performance)
VECTOR_WEIGHT=0.7
KG_WEIGHT=0.3
FUSION_STRATEGY=adaptive

# Storage
PERSIST_DIR=faiss_course_db
KG_PERSIST_DIR=knowledge_graph_db
COURSE_OUTLINES_FILE=course_outlines.jsonl

# Performance Settings
ENABLE_CACHING=true
EMBEDDING_BATCH_SIZE=32
NUM_WORKERS=4

# | Model                 | Dimension | Speed  | Accuracy in RAG             |
# | --------------------- | --------- | ------ | --------------------------- |
# | MiniLM-L6-v2          | 384       | Fast   | 🔹 Moderate                 |
# | **BGE-small-en-v1.5** | 384       | Fast   | ⭐ **Much better relevance** |
# | nomic-embed-text      | 768       | Medium | Good but slower             |
